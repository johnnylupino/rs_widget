
<div class="block-progresswidget" data-block="progresswidget" role="complementary" aria-label="{{#str}} pluginname, block_progresswidget {{/str}}">

{{#has_courses}}

    {{! ── Header ── }}
    <div class="pw-header mb-3">
        <div class="d-flex justify-content-between align-items-center">
            <h2 class="pw-title mb-0">{{#str}} pluginname, block_progresswidget {{/str}}</h2>
            <span class="pw-pill badge bg-light text-dark ms-2">{{total}} {{#str}} courses, block_progresswidget {{/str}}</span>
        </div>
    </div>

    {{! ── Doughnut — AMD wstrzykuje SVG tutaj ── }}
    <div class="pw-chart-target mb-3" role="img" aria-label="{{#str}} courseprogress, block_progresswidget {{/str}}" aria-hidden="true"></div>

    {{! ── Legenda ── }}
    <div class="pw-legend mb-3">

        <div>
            <div class="pw-legend-row">
                <div class="pw-legend-left">
                    <span class="pw-dot pw-dot-completed" role="presentation"></span>
                    <span class="pw-legend-label">{{#str}} state_completed, block_progresswidget {{/str}}</span>
                </div>
                <span class="pw-legend-count">{{completed}} <span class="pw-of">/ {{total}}</span></span>
            </div>
            <div class="pw-bar-track">
                <div class="pw-bar-fill pw-bar-completed" data-width="{{pct_completed}}"></div>
            </div>
        </div>

        <div>
            <div class="pw-legend-row">
                <div class="pw-legend-left">
                    <span class="pw-dot pw-dot-inprogress" role="presentation"></span>
                    <span class="pw-legend-label">{{#str}} state_inprogress, block_progresswidget {{/str}}</span>
                </div>
                <span class="pw-legend-count">{{inprogress}} <span class="pw-of">/ {{total}}</span></span>
            </div>
            <div class="pw-bar-track">
                <div class="pw-bar-fill pw-bar-inprogress" data-width="{{pct_inprogress}}"></div>
            </div>
        </div>

        <div>
            <div class="pw-legend-row">
                <div class="pw-legend-left">
                    <span class="pw-dot pw-dot-notstarted" role="presentation"></span>
                    <span class="pw-legend-label">{{#str}} state_notstarted, block_progresswidget {{/str}}</span>
                </div>
                <span class="pw-legend-count">{{notstarted}} <span class="pw-of">/ {{total}}</span></span>
            </div>
            <div class="pw-bar-track">
                <div class="pw-bar-fill pw-bar-notstarted" data-width="{{pct_notstarted}}"></div>
            </div>
        </div>

    </div>

    {{! ── Separator ── }}
    <hr class="pw-divider my-3" role="presentation" />

    {{! ── Lista kursów ── }}
    <ul class="pw-courses list-unstyled ps-0">
        {{#courses}}
        <li class="pw-course-row">

            {{! Ikona zależna od stanu — PHP ustawia is_completed / is_inprogress / is_notstarted }}

            {{#is_completed}}
            <div class="pw-course-icon pw-icon-completed" title="{{#str}} state_completed, block_progresswidget {{/str}}">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5"
                     stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true" role="presentation">
                    <polyline points="20 6 9 17 4 12"/>
                </svg>
            </div>
            {{/is_completed}}

            {{#is_inprogress}}
            <div class="pw-course-icon pw-icon-inprogress" title="{{#str}} state_inprogress, block_progresswidget {{/str}}">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true" role="presentation">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                </svg>
            </div>
            {{/is_inprogress}}

            {{#is_notstarted}}
            <div class="pw-course-icon pw-icon-notstarted" title="{{#str}} state_notstarted, block_progresswidget {{/str}}">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true" role="presentation">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
            </div>
            {{/is_notstarted}}

            {{! Nazwa kursu + pasek postępu }}
            <div class="pw-course-info">
                <div class="pw-course-name" title="{{fullname}}">{{fullname}}</div>
                {{^no_tracking}}
                <div class="pw-course-track">
                    <div class="pw-course-fill" data-width="{{pct}}" data-color="{{bar_color}}"></div>
                </div>
                {{/no_tracking}}
                {{#no_tracking}}
                <div class="pw-course-track"></div>
                {{/no_tracking}}
            </div>

            {{! Plakietka po prawej }}
            {{#is_completed}}
            <span class="pw-course-badge pw-badge-completed">{{#str}} state_completed, block_progresswidget {{/str}}</span>
            {{/is_completed}}
            {{#is_inprogress}}
            {{^no_tracking}}
            <span class="pw-course-badge pw-badge-inprogress">{{pct}}%</span>
            {{/no_tracking}}
            {{#no_tracking}}
            <span class="pw-course-badge pw-badge-notstarted">&mdash;</span>
            {{/no_tracking}}
            {{/is_inprogress}}
            {{#is_notstarted}}
            <span class="pw-course-badge pw-badge-notstarted">&mdash;</span>
            {{/is_notstarted}}

        </li>
        {{/courses}}
    </ul>

{{/has_courses}}

{{^has_courses}}
<div class="pw-empty">
    <p>{{#str}} nocourses, block_progresswidget {{/str}}</p>
</div>
{{/has_courses}}

</div>

{{#has_courses}}
<script>
(function() {
    'use strict';
    
    // Chart data passed from PHP template
    var chartData = {
        total:      {{total}},
        completed:  {{completed}},
        inprogress: {{inprogress}},
        notstarted: {{notstarted}},
        pct_completed:  {{pct_completed}},
        pct_inprogress: {{pct_inprogress}},
        pct_notstarted: {{pct_notstarted}},
        overall_progress: {{overall_progress}}
    };
    
    var COLORS = {
        completed:  '#1D9E75',
        inprogress: '#EF9F27',
        notstarted: '#B4B2A9'
    };
    
    var RADIUS = 75;
    var CX     = 100;
    var CY     = 100;
    var CIRC   = 2 * Math.PI * RADIUS;
    
    function buildArc(startFrac, endFrac, color, ariaLabel) {
        var arcLen  = (endFrac - startFrac) * CIRC;
        var offset  = CIRC - arcLen;
        var rotate  = startFrac * 360 - 90;
        
        return '<circle'
            + ' cx="' + CX + '" cy="' + CY + '" r="' + RADIUS + '"'
            + ' fill="none"'
            + ' stroke="' + color + '"'
            + ' stroke-width="18"'
            + ' stroke-linecap="butt"'
            + ' stroke-dasharray="' + CIRC.toFixed(3) + '"'
            + ' stroke-dashoffset="' + CIRC.toFixed(3) + '"'
            + ' data-target="' + offset.toFixed(4) + '"'
            + ' transform="rotate(' + rotate.toFixed(2) + ' ' + CX + ' ' + CY + ')"'
            + ' aria-label="' + ariaLabel + '"'
            + ' style="transition:stroke-dashoffset 0.9s cubic-bezier(0.4,0,0.2,1)"/>';
    }
    
    function renderChart() {
        var target = document.querySelector('.pw-chart-target');
        if (!target) return;
        
        var total      = chartData.total;
        var completed  = chartData.completed;
        var inprogress = chartData.inprogress;
        var notstarted = chartData.notstarted;
        
        // Use the average progress across all courses
        var pct = chartData.overall_progress;
        
        console.log('[ProgressWidget] Chart Data:', chartData);
        console.log('[ProgressWidget] Overall Progress:', pct + '%');
        
        var GAP = (total > 1) ? 0.008 : 0;
        var cur = 0;
        var fC  = completed  / (total > 0 ? total : 1);
        var fI  = inprogress / (total > 0 ? total : 1);
        var fN  = notstarted / (total > 0 ? total : 1);
        var arcs = '';
        
        if (fC > 0) {
            arcs += buildArc(cur, cur + fC - (fI > 0 || fN > 0 ? GAP : 0),
                COLORS.completed, completed + ' completed');
        }
        cur += fC;
        if (fI > 0) {
            arcs += buildArc(cur, cur + fI - (fN > 0 ? GAP : 0),
                COLORS.inprogress, inprogress + ' in progress');
        }
        cur += fI;
        if (fN > 0) {
            arcs += buildArc(cur, cur + fN,
                COLORS.notstarted, notstarted + ' not started');
        }
        
        target.innerHTML =
            '<div class="pw-chart-wrap">'
          +   '<svg viewBox="0 0 200 200" width="200" height="200"'
          +       ' role="img" aria-label="' + pct + '% overall progress">'
          +     '<circle cx="' + CX + '" cy="' + CY + '" r="' + RADIUS + '"'
          +         ' fill="none" stroke="#e9e9e7" stroke-width="18"/>'
          +     arcs
          +   '</svg>'
          +   '<div class="pw-centre" aria-hidden="true">'
          +     '<span class="pw-pct">' + pct + '%</span>'
          +     '<span class="pw-sub">progress</span>'
          +   '</div>'
          + '</div>';
        
        requestAnimationFrame(function () {
            var arcsEls = target.querySelectorAll('circle[data-target]');
            for (var i = 0; i < arcsEls.length; i++) {
                arcsEls[i].style.strokeDashoffset = arcsEls[i].getAttribute('data-target');
            }
        });
        
        // Animate bars
        requestAnimationFrame(function () {
            var fills = document.querySelectorAll('[data-width]');
            for (var i = 0; i < fills.length; i++) {
                fills[i].style.width = fills[i].getAttribute('data-width') + '%';
            }
        });
    }
    
    // Run when DOM is ready
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', renderChart);
    } else {
        renderChart();
    }
})();
</script>
{{/has_courses}}
